# === Rezervace backend / production ===
# Zkopírujte jako .env na produkčním serveru.

NODE_ENV=production
PORT=4000

# Databáze
# Příklad pro samostatný DB server:
# DATABASE_URL=mysql://rezervace_user:SuperHeslo@127.0.0.1:3306/stolni_tenis_rezervace
DATABASE_URL=mysql://rezervace_user:change-me@127.0.0.1:3306/stolni_tenis_rezervace

# Všechny frontend / admin domény, které smějí volat API
# Pokud frontend běží na stejné doméně a /api jde přes reverzní proxy,
# ponechte zde veřejnou doménu webu.
CORS_ORIGIN=https://rezervace.example.cz,https://www.rezervace.example.cz

# ZMĚŇTE před nasazením
ADMIN_AUTH_SECRET=change-me-to-a-long-random-secret
ADMIN_TOKEN_TTL_SECONDS=43200

# Výchozí minimální předstih rezervace v minutách
DEFAULT_MIN_ADVANCE_MINUTES=120

