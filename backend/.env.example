# === Backend Konfigurace Rezervačního Systému ===

# Databáze
# Development: MySQL na localhost bez hesla
# Production: Update s vlastními credentials
DATABASE_URL=mysql://root@localhost:3306/stolni_tenis_rezervace

# Server port
PORT=4000

# CORS Povolené origin domény (čárkou odděleno bez mezer)
# Development (frontend na localhost)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173, https://rezervace.tt-denik.cz/

# Production (iframe nasazení)
# Přidejte všechny domény, ze kterých chcete povolit přístup:
# CORS_ORIGIN=https://tvuj-server.cz,https://www.tvuj-server.cz,https://jiny-web.cz

# Admin JWT secret (ZMĚŇTE NA SILNÉ HESLO V PRODUKCI!)
# Příklad: openssl rand -base64 32
ADMIN_AUTH_SECRET=change-me-admin-secret

# Admin token TTL v sekundách (výchozí 12 hodin)
ADMIN_TOKEN_TTL_SECONDS=43200

