# === Frontend Konfigurace Rezervačního Systému ===

# API URL
# Development: Pokud není nastaveno, aplikace zkusí automaticky najít API na:
#   1. Relativní cestě (stejný origin jako frontend)
#   2. http://localhost:4000
#   3. http://127.0.0.1:4000
#
# Production na jiné doméně:
#   VITE_API_URL=https://api.tvuj-server.cz
#
# Production na stejné doméně (relativní path, doporučeno pro iframe):
#   VITE_API_URL=/api

VITE_API_URL=http://localhost:4000

